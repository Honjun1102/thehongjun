---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { essays } from "../data/essays";
import { pillars, siteMeta } from "../data/site";
import { vectorSeries } from "../data/vectorSeries";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteMeta.title,
  url: new URL("/", Astro.site ?? "https://www.thehongjun.com").toString(),
  description: siteMeta.description,
  inLanguage: "zh-CN",
};

const chronological = [...essays].sort(
  (a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime(),
);
const leadEssay = chronological[0];
const latestEssays = chronological.slice(1, 6);

const publications = [
  {
    type: "专题",
    title: vectorSeries.title,
    description: vectorSeries.description,
    href: vectorSeries.href,
  },
  {
    type: "书稿",
    title: "文明生存树",
    description: "从生存公理出发，重新理解群体、制度、历史与文明的完整长书。",
    href: "/books/civilization-survival-tree/",
  },
];
---

<Layout title={siteMeta.title} description={siteMeta.description} structuredData={structuredData}>
  <SiteHeader />

  <main class="shell home">
    <section class="frontispiece">
      <div class="manifesto reveal reveal-one">
        <p class="eyebrow">一份关于人的独立刊物</p>
        <h1>
          <span>别让这个时代，</span>
          <span>替你活完一生。</span>
        </h1>
        <p class="manifesto-copy">
          把身体、判断和生计，一样一样拿回来。这里写技术、历史与文明，但最终只追问一件事：一个人怎样不把自己交出去。
        </p>
        <a class="text-link" href="/start-here/">从第一篇开始 <span aria-hidden="true">→</span></a>
      </div>

      <aside class="editor-note reveal reveal-two">
        <span>编者的话</span>
        <p>真正的主权，始于你还能感受自己的身体，还能用自己的语言解释世界，还能保护自己想过的生活。</p>
        <small>Hong Jun · 2026 夏</small>
      </aside>
    </section>

    <section class="lead-story reveal reveal-three" aria-labelledby="lead-heading">
      <div class="section-label">
        <span>本期主打</span>
        <time datetime={leadEssay.publishedAt}>{leadEssay.publishedAt}</time>
      </div>

      <a class="lead-link" href={`/essays/${leadEssay.slug}/`}>
        <div class="lead-number" aria-hidden="true">01</div>
        <div class="lead-copy">
          <p>{leadEssay.category}</p>
          <h2 id="lead-heading">{leadEssay.title}</h2>
          <span>{leadEssay.description}</span>
          <strong>阅读全文 <i aria-hidden="true">↗</i></strong>
        </div>
      </a>
    </section>

    <section class="latest" aria-labelledby="latest-heading">
      <header class="section-heading">
        <p class="eyebrow">最近发表</p>
        <h2 id="latest-heading">持续写作，不追逐信息流。</h2>
        <a href="/essays/">全部文章 →</a>
      </header>

      <div class="story-list">
        {
          latestEssays.map((essay, index) => (
            <a href={`/essays/${essay.slug}/`} class="story-row">
              <span class="story-index">{String(index + 2).padStart(2, "0")}</span>
              <div>
                <p>{essay.category}</p>
                <h3>{essay.title}</h3>
              </div>
              <time datetime={essay.publishedAt}>{essay.publishedAt}</time>
              <span class="story-arrow" aria-hidden="true">→</span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="themes" aria-labelledby="themes-heading">
      <header class="theme-intro">
        <p class="eyebrow">三条主线</p>
        <h2 id="themes-heading">人要站稳，至少需要三根支柱。</h2>
      </header>

      <div class="theme-list">
        {
          pillars.map((pillar, index) => (
            <article>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{pillar.title}</h3>
              <p>{pillar.description}</p>
              <a href={`/essays/#${pillar.key}`}>进入这条线 →</a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="publications" aria-labelledby="publications-heading">
      <div class="publication-title">
        <p class="eyebrow">长线出版</p>
        <h2 id="publications-heading">有些问题，不能用一篇文章讲完。</h2>
      </div>

      <div class="publication-list">
        {
          publications.map((item) => (
            <a href={item.href}>
              <span>{item.type}</span>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
              <strong>继续阅读 ↗</strong>
            </a>
          ))
        }
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>

<style>
  .home {
    padding-bottom: clamp(5rem, 10vw, 9rem);
  }

  .frontispiece {
    display: grid;
    grid-template-columns: minmax(0, 1.65fr) minmax(16rem, 0.55fr);
    gap: clamp(2rem, 6vw, 6rem);
    min-height: min(44rem, calc(100vh - 9rem));
    padding: clamp(4rem, 10vw, 9rem) 0 clamp(3rem, 7vw, 6rem);
    align-items: end;
  }

  .manifesto h1 {
    max-width: 9.5em;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 8.5vw, 7.5rem);
    font-weight: 400;
    line-height: 1.03;
    letter-spacing: -0.055em;
    text-wrap: balance;
  }

  .manifesto h1 span {
    display: block;
    max-width: 100%;
    white-space: nowrap;
  }

  .manifesto-copy {
    max-width: 38rem;
    margin: 2rem 0 1.4rem;
    color: var(--ink-soft);
    font-family: var(--font-serif);
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    line-height: 1.95;
  }

  .text-link {
    display: inline-flex;
    gap: 0.65rem;
    align-items: center;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--ink);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .text-link span {
    color: var(--accent);
    transition: transform 160ms ease;
  }

  .text-link:hover span {
    transform: translateX(0.3rem);
  }

  .editor-note {
    padding: 1.25rem 0 0 1.25rem;
    border-top: 1px solid var(--accent);
    border-left: 1px solid var(--line);
  }

  .editor-note span,
  .section-label,
  .story-index,
  .story-row time,
  .lead-copy > p,
  .publication-list > a > span {
    color: var(--accent);
    font: 500 0.7rem/1.4 var(--font-mono);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .editor-note p {
    margin: 1.2rem 0;
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.9;
  }

  .editor-note small {
    color: var(--ink-muted);
    font-size: 0.75rem;
  }

  .lead-story,
  .latest,
  .themes,
  .publications {
    border-top: 3px solid var(--ink);
  }

  .section-label {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.8rem 0;
    border-bottom: 1px solid var(--line-dark);
  }

  .section-label time {
    color: var(--ink-muted);
  }

  .lead-link {
    display: grid;
    grid-template-columns: minmax(10rem, 0.48fr) minmax(0, 1.52fr);
    min-height: 31rem;
    border-bottom: 1px solid var(--line-dark);
  }

  .lead-number {
    display: flex;
    align-items: flex-start;
    padding: 1.4rem 1.5rem 1.5rem 0;
    color: var(--accent);
    font-family: var(--font-display);
    font-size: clamp(7rem, 18vw, 14rem);
    line-height: 0.8;
    border-right: 1px solid var(--line-dark);
  }

  .lead-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding: clamp(2rem, 6vw, 5rem);
  }

  .lead-copy h2 {
    max-width: 13em;
    margin: 0.8rem 0 1.2rem;
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5.5vw, 5.2rem);
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .lead-copy > span {
    max-width: 38rem;
    color: var(--ink-muted);
    font-family: var(--font-serif);
    line-height: 1.9;
  }

  .lead-copy strong {
    margin-top: 2rem;
    font-size: 0.85rem;
  }

  .lead-copy i {
    color: var(--accent);
    font-style: normal;
  }

  .section-heading,
  .theme-intro,
  .publication-title {
    display: grid;
    grid-template-columns: 0.45fr 1.35fr auto;
    gap: 2rem;
    align-items: baseline;
    padding: 1.25rem 0 2.5rem;
  }

  .section-heading h2,
  .theme-intro h2,
  .publication-title h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.8rem);
    font-weight: 400;
    line-height: 1.15;
  }

  .section-heading > a {
    color: var(--accent);
    font-size: 0.8rem;
  }

  .latest,
  .themes,
  .publications {
    margin-top: clamp(5rem, 10vw, 9rem);
  }

  .story-row {
    display: grid;
    grid-template-columns: 4.5rem minmax(0, 1fr) auto 2rem;
    gap: 1.2rem;
    align-items: center;
    padding: 1.25rem 0;
    border-top: 1px solid var(--line);
    transition: padding 180ms ease, color 180ms ease;
  }

  .story-row:last-child {
    border-bottom: 1px solid var(--line);
  }

  .story-row:hover {
    padding-left: 0.75rem;
    color: var(--accent-dark);
  }

  .story-row p,
  .story-row h3 {
    margin: 0;
  }

  .story-row p {
    margin-bottom: 0.35rem;
    color: var(--ink-muted);
    font-size: 0.72rem;
  }

  .story-row h3 {
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 2vw, 1.45rem);
    font-weight: 600;
    line-height: 1.4;
  }

  .story-row time {
    color: var(--ink-muted);
    letter-spacing: 0;
  }

  .story-arrow {
    color: var(--accent);
  }

  .theme-intro,
  .publication-title {
    grid-template-columns: 0.45fr 1.55fr;
  }

  .theme-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--line-dark);
    border-bottom: 1px solid var(--line-dark);
  }

  .theme-list article {
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    gap: 1rem;
    min-height: 23rem;
    padding: 1.5rem;
    border-left: 1px solid var(--line);
  }

  .theme-list article:first-child {
    border-left: 0;
    padding-left: 0;
  }

  .theme-list span {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .theme-list h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 400;
  }

  .theme-list p {
    margin: 0;
    color: var(--ink-muted);
    line-height: 1.9;
  }

  .theme-list a {
    color: var(--accent);
    font-size: 0.8rem;
  }

  .publication-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border-top: 1px solid var(--line-dark);
    border-bottom: 1px solid var(--line-dark);
  }

  .publication-list > a {
    display: grid;
    align-content: start;
    min-height: 19rem;
    padding: 1.5rem;
    border-left: 1px solid var(--line);
  }

  .publication-list > a:first-child {
    padding-left: 0;
    border-left: 0;
  }

  .publication-list h3 {
    margin: 1.2rem 0 0.8rem;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.4rem);
    font-weight: 400;
  }

  .publication-list p {
    max-width: 34rem;
    margin: 0;
    color: var(--ink-muted);
    line-height: 1.85;
  }

  .publication-list strong {
    margin-top: auto;
    padding-top: 2rem;
    color: var(--accent);
    font-size: 0.8rem;
  }

  .reveal {
    animation: reveal-up 700ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .reveal-two {
    animation-delay: 120ms;
  }

  .reveal-three {
    animation-delay: 220ms;
  }

  @keyframes reveal-up {
    from {
      opacity: 0;
      transform: translateY(1.2rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 860px) {
    .frontispiece,
    .lead-link,
    .section-heading,
    .theme-intro,
    .publication-title {
      grid-template-columns: 1fr;
    }

    .frontispiece {
      min-height: auto;
      padding-top: 5rem;
    }

    .editor-note {
      max-width: 30rem;
    }

    .lead-number {
      min-height: 9rem;
      padding: 1.25rem 0;
      border-right: 0;
      border-bottom: 1px solid var(--line);
      font-size: 7.5rem;
    }

    .lead-copy {
      padding: 2.5rem 0;
    }

    .theme-list,
    .publication-list {
      grid-template-columns: 1fr;
    }

    .theme-list article,
    .theme-list article:first-child,
    .publication-list > a,
    .publication-list > a:first-child {
      min-height: auto;
      padding: 1.5rem 0;
      border-left: 0;
      border-top: 1px solid var(--line);
    }

    .theme-list article:first-child,
    .publication-list > a:first-child {
      border-top: 0;
    }
  }

  @media (max-width: 600px) {
    .manifesto h1 {
      max-width: 100%;
      font-size: clamp(2.1rem, 10.5vw, 3.4rem);
      letter-spacing: -0.045em;
    }

    .story-row {
      grid-template-columns: 2.5rem minmax(0, 1fr) 1rem;
      gap: 0.75rem;
    }

    .story-row time {
      display: none;
    }
  }
</style>
