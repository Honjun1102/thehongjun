---
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import EssayCard from "../../components/EssayCard.astro";
import { essays } from "../../data/essays";
import { getEnglishSlugFromChinese } from "../../data/essayLinks";
import { siteMeta } from "../../data/site";

const pageDescription =
  "关于身体、思想、生计与人生重建的写作。先读总纲，再进入中篇，按自己的问题一路深入。";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `Essays | ${siteMeta.title}`,
  url: new URL("/essays/", Astro.site ?? "https://www.thehongjun.com").toString(),
  description: pageDescription,
  inLanguage: "zh-CN",
};

const orderedEssays = [...essays].sort((a, b) => a.order - b.order);
const foundationalEssays = orderedEssays.filter((essay) => essay.featured);
const extendedEssays = orderedEssays.filter((essay) => !essay.featured);

const categoryMeta = {
  身体: { number: "01", title: "身体", blurb: "感知、精力与行动力，是一切重建真正发生的地方。" },
  思想: { number: "02", title: "思想", blurb: "建立解释世界的框架，而不是活在别人的口号里。" },
  生计: { number: "03", title: "生计", blurb: "建立不完全依赖岗位施舍的独立生计能力。" },
} as const;

const extendedGroups = (Object.keys(categoryMeta) as Array<keyof typeof categoryMeta>)
  .map((category) => ({
    category,
    meta: categoryMeta[category],
    essays: extendedEssays.filter((essay) => essay.category === category),
  }))
  .filter((group) => group.essays.length > 0);
---

<Layout title={`文章 | ${siteMeta.title}`} description={pageDescription} structuredData={structuredData}>
  <SiteHeader />

  <main class="shell archive">
    <header class="archive-head">
      <div>
        <p class="kicker">文章 / Essays</p>
        <h1>一套阅读路径，<br />不是信息流。</h1>
      </div>
      <div class="archive-intro">
        <p>这里的文章围绕身体、思想、生计与主权重建展开。它们不追逐更新速度，而试图把一个问题想得更深、更完整。</p>
        <p class="archive-note">建议先读四篇总纲，再从你当下最迫切的问题进入。</p>
      </div>
    </header>

    <section class="archive-section" aria-labelledby="foundations-title">
      <div class="section-mark">
        <span>卷首</span>
        <span>{String(foundationalEssays.length).padStart(2, "0")} 篇</span>
      </div>
      <div class="section-content">
        <header class="section-head">
          <h2 id="foundations-title">总纲</h2>
          <p>主权、时代、历史、人民。先建立一张地图，再决定往哪里走。</p>
        </header>
        <div class="essay-list">
          {foundationalEssays.map((essay) => (
            <EssayCard
              href={`/essays/${essay.slug}/`}
              title={essay.title}
              description={essay.description}
              publishedAt={essay.publishedAt}
              category={essay.category}
              languageNote={getEnglishSlugFromChinese(essay.slug) ? "中 / EN" : undefined}
            />
          ))}
        </div>
      </div>
    </section>

    {extendedGroups.map((group) => (
      <section class="archive-section" aria-labelledby={`group-${group.category}`}>
        <div class="section-mark">
          <span>{group.meta.number}</span>
          <span>{String(group.essays.length).padStart(2, "0")} 篇</span>
        </div>
        <div class="section-content">
          <header class="section-head">
            <h2 id={`group-${group.category}`}>{group.meta.title}</h2>
            <p>{group.meta.blurb}</p>
          </header>
          <div class="essay-list">
            {group.essays.map((essay) => (
              <EssayCard
                href={`/essays/${essay.slug}/`}
                title={essay.title}
                description={essay.description}
                publishedAt={essay.publishedAt}
                category={essay.category}
                languageNote={getEnglishSlugFromChinese(essay.slug) ? "中 / EN" : undefined}
              />
            ))}
          </div>
        </div>
      </section>
    ))}
  </main>

  <SiteFooter />
</Layout>

<style>
  .archive {
    padding-top: clamp(3rem, 7vw, 7rem);
    padding-bottom: clamp(4rem, 9vw, 8rem);
  }

  .archive-head {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.8fr);
    gap: clamp(2rem, 7vw, 7rem);
    align-items: end;
    padding-bottom: clamp(3rem, 7vw, 6rem);
  }

  .archive-head h1 {
    max-width: 12ch;
    margin: 0.6rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6.8rem);
    font-weight: 600;
    line-height: 0.98;
    letter-spacing: -0.06em;
  }

  .archive-intro {
    padding-left: 1.25rem;
    border-left: 1px solid var(--accent);
  }

  .archive-intro p {
    margin: 0;
    color: var(--ink-muted);
    font-size: 1.02rem;
    line-height: 1.9;
  }

  .archive-intro .archive-note {
    margin-top: 1.2rem;
    color: var(--ink);
    font-family: var(--font-display);
  }

  .archive-section {
    display: grid;
    grid-template-columns: minmax(7rem, 0.25fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 5vw, 5rem);
    padding: clamp(2.5rem, 6vw, 5rem) 0;
    border-top: 1px solid rgba(23, 21, 18, 0.35);
  }

  .section-mark {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    color: var(--ink-muted);
    font: 500 0.72rem/1.3 var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .section-mark span:first-child {
    color: var(--accent);
  }

  .section-head {
    display: grid;
    grid-template-columns: minmax(8rem, 0.55fr) minmax(16rem, 1fr);
    gap: 2rem;
    align-items: baseline;
    padding-bottom: 1.75rem;
  }

  .section-head h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 1;
  }

  .section-head p {
    max-width: 36rem;
    margin: 0;
    color: var(--ink-muted);
    line-height: 1.8;
  }

  .essay-list {
    border-bottom: 1px solid rgba(23, 21, 18, 0.18);
  }

  @media (max-width: 800px) {
    .archive-head,
    .archive-section {
      grid-template-columns: 1fr;
    }

    .archive-head {
      align-items: start;
    }

    .archive-section {
      gap: 1.5rem;
    }

    .section-mark {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  @media (max-width: 560px) {
    .archive-head h1 {
      font-size: clamp(2.75rem, 15vw, 4.4rem);
    }

    .section-head {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
  }
</style>
