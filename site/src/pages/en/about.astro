---
import Layout from "../../layouts/Layout.astro";
import EnglishHeader from "../../components/EnglishHeader.astro";
import EnglishFooter from "../../components/EnglishFooter.astro";
import { englishAboutSections, englishSiteMeta } from "../../data/english";
---

<Layout title={`About | ${englishSiteMeta.title}`} description="Who this project is for, why it exists, and what worldview holds it together.">
  <EnglishHeader />

  <main class="shell section">
    <section class="page-intro">
      <p class="kicker">About</p>
      <h1 class="page-title">This is not a resume. It is a declaration of position.</h1>
      <p class="lede">
        I am less interested in helping people adapt faster than in helping them stop
        losing themselves. Anxiety is often not just emotion but a loss of coordinates.
        So this site starts with the main problem, then the larger explanations of age,
        system, and history, and only then returns to the layers that land on a real
        life: body, thought, and livelihood.
      </p>
    </section>

    <section class="about-grid">
      {
        englishAboutSections.map((section) => (
          <article class="card panel about-card">
            <h2>{section.title}</h2>
            <p>{section.body}</p>
          </article>
        ))
      }
    </section>

    <section class="card panel closing">
      <p class="kicker">For Readers</p>
      <h2>For those who already feel that something is structurally wrong.</h2>
      <p>
        If you already suspect that attention systems are colonizing thought, that
        work is becoming dependence, and that modern life has turned the body into a
        neglected shell, this project is written for you.
      </p>
      <p>
        I am trying to build a serious writer's home around reconstruction: body and
        thought as roots, livelihood as protection, and trust as the basis for real
        cooperation and larger work. First restore coordinates, then help a person
        stand again, and only then talk about scale.
      </p>
    </section>
  </main>

  <EnglishFooter />
</Layout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .about-card,
  .closing {
    display: grid;
    gap: 0.85rem;
  }

  .about-card h2,
  .closing h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.2;
  }

  .about-card p,
  .closing p {
    margin: 0;
    color: var(--ink-muted);
    line-height: 1.9;
  }

  @media (max-width: 960px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
